generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Difficulty {
  CORE
  STANDARD
  HARD
  INSANE
}

enum LearningPointOrigin {
  MANUAL
  PERPLEXITY
  LLM
}

enum UserRole {
  ADMIN
  EDITOR
  LEARNER
}

model User {
  id           String   @id @default(cuid())
  name         String
  loginId      String   @unique
  passwordHash String
  role         UserRole @default(LEARNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  learningPoints LearningPoint[] @relation("LearningPointCreator")
  questionDrafts QuestionDraft[] @relation("QuestionDraftCreator")
  questionSets   QuestionSet[]   @relation("QuestionSetCreator")
  exams          Exam[]          @relation("ExamCreator")

  attempts      UserAttempt[]
  examAttempts  ExamAttempt[]
  goodReactions DraftGood[]
  raiseHands    DraftRaiseHand[]
}

model LearningPoint {
  id            String              @id @default(cuid())
  createdById   String?
  topic         String
  subtopic      String?
  title         String
  learningPoint String              @db.Text
  rationale     String?             @db.Text
  difficulty    Difficulty
  tags          String[]
  origin        LearningPointOrigin @default(PERPLEXITY)

  generatedByModel String?
  generationMeta   Json?
  lastGeneratedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User? @relation("LearningPointCreator", fields: [createdById], references: [id], onDelete: SetNull)

  drafts     QuestionDraft[]
  references LearningPointReference[]

  @@index([topic])
  @@index([subtopic])
  @@index([origin])
  @@index([createdById])
  @@index([difficulty])
  @@index([updatedAt])
  @@index([topic, difficulty])
}

model LearningPointReference {
  id              String   @id @default(cuid())
  learningPointId String
  url             String
  orderIndex      Int      @default(0)
  createdAt       DateTime @default(now())

  learningPoint LearningPoint @relation(fields: [learningPointId], references: [id], onDelete: Cascade)

  @@unique([learningPointId, url])
  @@index([learningPointId])
  @@index([url])
  @@index([learningPointId, orderIndex])
}

model ImageAsset {
  id           String  @id @default(cuid())
  fileUrl      String
  thumbnailUrl String?

  createdAt DateTime @default(now())

  questionDrafts QuestionDraft[]

  @@index([createdAt])
}

model QuestionDraft {
  id              String  @id @default(cuid())
  learningPointId String
  imageAssetId    String?
  createdById     String?
  version         Int     @default(1)

  stem          String @db.Text
  choiceA       String @db.Text
  choiceB       String @db.Text
  choiceC       String @db.Text
  choiceD       String @db.Text
  correctAnswer String

  explanation  String  @db.Text
  explanationA String? @db.Text
  explanationB String? @db.Text
  explanationC String? @db.Text
  explanationD String? @db.Text

  llmProvider    String?
  llmModel       String?
  promptVersion  String?
  generationMeta Json?

  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  learningPoint LearningPoint @relation(fields: [learningPointId], references: [id], onDelete: Cascade)
  imageAsset    ImageAsset?   @relation(fields: [imageAssetId], references: [id], onDelete: SetNull)
  createdBy     User?         @relation("QuestionDraftCreator", fields: [createdById], references: [id], onDelete: SetNull)

  attempts   UserAttempt[]
  goods      DraftGood[]
  raiseHands DraftRaiseHand[]
  setItems   QuestionSetItem[]
  examItems  ExamItem[]

  @@index([learningPointId])
  @@index([imageAssetId])
  @@index([createdById])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([updatedAt])
  @@index([isPublished, publishedAt])
  @@index([isPublished, learningPointId])
}

model DraftGood {
  id              String   @id @default(cuid())
  questionDraftId String
  userId          String
  createdAt       DateTime @default(now())

  draft QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionDraftId, userId])
  @@index([questionDraftId])
  @@index([userId])
}

model DraftRaiseHand {
  id              String   @id @default(cuid())
  questionDraftId String
  userId          String
  comment         String   @db.Text
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  draft QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionDraftId])
  @@index([userId])
  @@index([resolved])
}

model QuestionSet {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  createdById String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User?             @relation("QuestionSetCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items     QuestionSetItem[]

  @@index([createdById])
  @@index([isPublished])
}

model QuestionSetItem {
  id              String   @id @default(cuid())
  questionSetId   String
  questionDraftId String
  orderIndex      Int
  createdAt       DateTime @default(now())

  questionSet QuestionSet   @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  draft       QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)

  @@unique([questionSetId, questionDraftId])
  @@unique([questionSetId, orderIndex])
  @@index([questionSetId])
  @@index([questionDraftId])
}

model UserAttempt {
  id              String   @id @default(cuid())
  userId          String
  questionDraftId String
  selectedAnswer  String
  isCorrect       Boolean
  answeredAt      DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionDraftId])
  @@index([answeredAt])
}

model Exam {
  id                     String    @id @default(cuid())
  title                  String
  description            String?   @db.Text
  predictedMeanScore     Float?
  predictedStdDev        Float?
  passDeviationThreshold Float?
  isPublished            Boolean   @default(false)
  publishedAt            DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("ExamCreator", fields: [createdById], references: [id], onDelete: SetNull)

  items    ExamItem[]
  attempts ExamAttempt[]

  @@index([createdById])
  @@index([isPublished])
}

model ExamItem {
  id              String   @id @default(cuid())
  examId          String
  questionDraftId String
  orderIndex      Int
  createdAt       DateTime @default(now())

  exam  Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  draft QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)

  @@unique([examId, questionDraftId])
  @@unique([examId, orderIndex])
  @@index([examId])
  @@index([questionDraftId])
}

model ExamAttempt {
  id             String   @id @default(cuid())
  examId         String
  userId         String
  score          Int
  totalQuestions Int
  deviation      Float?
  passed         Boolean?
  completedAt    DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([userId])
}
