generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SourceType {
  TEXTBOOK
  GUIDELINE
  PAPER
  PAST_EXAM
  NOTE
}

enum SourceStatus {
  ACTIVE
  ARCHIVED
}

enum Difficulty {
  CORE
  STANDARD
  HARD
  INSANE
}

enum QuestionStyle {
  FACT
  CASE
  DIFFERENTIAL
  TREATMENT
  IMAGE
}

enum ImageModality {
  MRI
  CT
  EEG
  EMG
  NCS
  PATHOLOGY
  MUSCLE_PATHOLOGY
  CLINICAL_PHOTO
  FUNDUS
  PET
  ULTRASOUND
  OTHER
}

enum ImageAssetStatus {
  ACTIVE
  ARCHIVED
}

enum LearningPointOrigin {
  MANUAL
  LLM
  SOURCE_LLM
}

model Source {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        SourceType
  author      String?
  year        Int?
  fileUrl     String?
  rawText     String?
  status      SourceStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  chunks         SourceChunk[]
  learningPoints LearningPoint[]
  images         ImageAsset[]
}

model SourceChunk {
  id         String   @id @default(cuid())
  sourceId   String
  chunkIndex Int
  chapter    String?
  pageStart  Int?
  pageEnd    Int?
  text       String   @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  citedInDrafts QuestionDraftCitation[]

  @@unique([sourceId, chunkIndex])
  @@index([sourceId])
}

enum UserRole {
  ADMIN
  EDITOR
  LEARNER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  role      UserRole @default(LEARNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  learningPoints LearningPoint[] @relation("LearningPointCreator")
  questionDrafts QuestionDraft[] @relation("QuestionDraftCreator")
  questionSets   QuestionSet[]   @relation("QuestionSetCreator")

  attempts      UserAttempt[]
  goodReactions DraftGood[]
  raiseHands    DraftRaiseHand[]
}

model LearningPoint {
  id              String              @id @default(cuid())
  sourceId        String?
  createdById     String?
  topic           String
  subtopic        String?
  title           String
  learningPoint   String              @db.Text
  rationale       String?             @db.Text
  difficulty      Difficulty
  questionStyle   QuestionStyle
  tags            String[]
  sourcePriority  Int                 @default(0)
  origin          LearningPointOrigin
  lastGeneratedAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  source    Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  createdBy User?   @relation("LearningPointCreator", fields: [createdById], references: [id], onDelete: SetNull)

  drafts     QuestionDraft[]
  imageLinks LearningPointImage[]

  @@index([topic])
  @@index([subtopic])
  @@index([origin])
  @@index([createdById])
  @@index([difficulty])
  @@index([updatedAt])
  @@index([topic, difficulty])
}

model LearningPointImage {
  id              String   @id @default(cuid())
  learningPointId String
  imageAssetId    String
  note            String?
  createdAt       DateTime @default(now())

  learningPoint LearningPoint @relation(fields: [learningPointId], references: [id], onDelete: Cascade)
  imageAsset    ImageAsset    @relation(fields: [imageAssetId], references: [id], onDelete: Cascade)

  @@unique([learningPointId, imageAssetId])
  @@index([learningPointId])
  @@index([imageAssetId])
}

model ImageAsset {
  id            String           @id @default(cuid())
  sourceId      String?
  title         String
  description   String?          @db.Text
  fileUrl       String
  thumbnailUrl  String?
  modality      ImageModality
  topic         String
  subtopic      String?
  diagnosis     String?
  findings      String?          @db.Text
  notes         String?          @db.Text
  sourceLabel   String?
  sourceYear    Int?
  copyrightNote String?
  status        ImageAssetStatus @default(ACTIVE)
  tags          String[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  source Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  learningPoints LearningPointImage[]
  questionDrafts QuestionDraft[]

  @@index([topic])
  @@index([subtopic])
  @@index([modality])
  @@index([status])
}

model QuestionDraft {
  id              String  @id @default(cuid())
  learningPointId String
  imageAssetId    String?
  createdById     String?
  version         Int     @default(1)

  stem          String @db.Text
  choiceA       String @db.Text
  choiceB       String @db.Text
  choiceC       String @db.Text
  choiceD       String @db.Text
  correctAnswer String

  explanation  String  @db.Text
  explanationA String? @db.Text
  explanationB String? @db.Text
  explanationC String? @db.Text
  explanationD String? @db.Text

  llmModel       String?
  promptVersion  String?
  generationMeta Json?

  hasImage    Boolean   @default(false)
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  learningPoint LearningPoint @relation(fields: [learningPointId], references: [id], onDelete: Cascade)
  imageAsset    ImageAsset?   @relation(fields: [imageAssetId], references: [id], onDelete: SetNull)
  createdBy     User?         @relation("QuestionDraftCreator", fields: [createdById], references: [id], onDelete: SetNull)

  citations  QuestionDraftCitation[]
  attempts   UserAttempt[]
  goods      DraftGood[]
  raiseHands DraftRaiseHand[]
  setItems   QuestionSetItem[]

  @@index([learningPointId])
  @@index([imageAssetId])
  @@index([createdById])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([updatedAt])
  @@index([isPublished, publishedAt])
  @@index([isPublished, learningPointId])
}

model QuestionDraftCitation {
  id              String   @id @default(cuid())
  questionDraftId String
  sourceChunkId   String
  note            String?
  createdAt       DateTime @default(now())

  questionDraft QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)
  sourceChunk   SourceChunk   @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade)

  @@index([questionDraftId])
  @@index([sourceChunkId])
}

model DraftGood {
  id              String   @id @default(cuid())
  questionDraftId String
  userId          String
  createdAt       DateTime @default(now())

  draft QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionDraftId, userId])
  @@index([questionDraftId])
  @@index([userId])
}

model DraftRaiseHand {
  id              String   @id @default(cuid())
  questionDraftId String
  userId          String
  comment         String   @db.Text
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  draft QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionDraftId])
  @@index([userId])
  @@index([resolved])
}

model QuestionSet {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?             @relation("QuestionSetCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items     QuestionSetItem[]

  @@index([createdById])
}

model QuestionSetItem {
  id              String   @id @default(cuid())
  questionSetId   String
  questionDraftId String
  orderIndex      Int
  createdAt       DateTime @default(now())

  questionSet QuestionSet   @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  draft       QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)

  @@unique([questionSetId, questionDraftId])
  @@unique([questionSetId, orderIndex])
  @@index([questionSetId])
  @@index([questionDraftId])
}

model UserAttempt {
  id              String   @id @default(cuid())
  userId          String
  questionDraftId String
  selectedAnswer  String
  isCorrect       Boolean
  answeredAt      DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft QuestionDraft @relation(fields: [questionDraftId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionDraftId])
  @@index([answeredAt])
}
